# Monitoring package settings (MONITOR_ prefix)
MONITOR_ENABLED=true
MONITOR_LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
MONITOR_LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
MONITOR_LANGFUSE_HOST=http://localhost:3000
MONITOR_LANGFUSE_RELEASE=dev
MONITOR_OTEL_SERVICE_NAME=rag-pipeline
MONITOR_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
MONITOR_PRICING_FILE=pricing.json
MONITOR_BASELINE_DIR=data/monitoring

# Docker Compose infrastructure secrets (required when running infra/docker-compose.yml)
POSTGRES_PASSWORD=change-me-strong-password
LANGFUSE_NEXTAUTH_SECRET=change-me-random-32-char-secret
LANGFUSE_SALT=change-me-random-salt
GF_ADMIN_PASSWORD=change-me-grafana-admin-password
